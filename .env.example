# ============================================
# TC Accounts (TCID) Authentication
# ============================================
# Leave NUXT_TCID_CLIENT_ID empty to disable auth (all pages public).
# When configured, pages require TCID authentication via tc-accounts.
# Note: NUXT_* env var names are kept for backward compatibility with ECS/CDK task definitions.
#
# OAuth Client: "Trilogy Care Docs" (registered in tc-accounts)
#   Client ID: 714f6636-b5ba-48b3-b107-bd17508efd2a
#   Redirect URIs (already registered):
#     - https://docs.trilogycare.com.au/api/auth/tcid/callback
#     - https://localhost:3000/api/auth/tcid/callback
#
# To get the client secret: ask a tc-accounts admin, or check
# AWS Secrets Manager / ECS task definition in the prod account.
#
# For local dev with auth:
#   1. Copy this file to .env.local
#   2. Fill in NUXT_TCID_CLIENT_ID and NUXT_TCID_CLIENT_SECRET
#   3. Run: npm run dev
#   4. Sign in at http://localhost:3000 via Microsoft SSO
#
NUXT_TCID_CLIENT_ID=
NUXT_TCID_CLIENT_SECRET=
NUXT_TCID_ISSUER_URL=https://accounts.trilogycare.com.au
NUXT_PUBLIC_APP_URL=https://localhost:3000

# ============================================
# Typesense Cloud Search Configuration
#
# TYPESENSE_ADMIN_KEY: Admin API key for indexing (used in CI/CD)
# - Set this as a GitHub Actions secret, NOT in .env
# - Only needed during build time to index content
#
# TYPESENSE_SEARCH_KEY: Search-only API key for frontend search
# - Safe to expose in client-side code
# - Get this from Typesense Cloud dashboard

TYPESENSE_SEARCH_KEY=your_search_only_api_key_here

# Optional: Path to initiatives content
INITIATIVES_PATH=

# ============================================
# Usage Dashboard (Neon PostgreSQL + Drizzle)
# ============================================
# Leave DATABASE_URL empty to disable usage features.
DATABASE_URL=
DATABASE_URL_UNPOOLED=
TEAM_SECRET=
